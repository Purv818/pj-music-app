{
  "appId": "com.pjmusicapp.app",
  "appName": "PJ Music",
  "webDir": ".",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0f0f1a"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f0f1a",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "dark"
    },
    "Filesystem": {
      "iosScheme": "capacitor"
    }
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
