# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Free cluster: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/pjmusic
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/pjmusic

# ─── JWT Secrets ────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=paste_64_char_random_string_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=paste_another_64_char_random_string_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS — Allowed Origins ──────────────────────────────────────────────────────
# Apna Railway frontend URL + capacitor app
# Leave empty to allow ALL origins (ok for development)
ALLOWED_ORIGINS=

# ─── Rate Limiting ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20

# ─── Security ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=10
